{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TimelineProjectV2",
  "description": "Universal v2 schema for Arm 10 process timelines and revisions.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "project_id": {
      "type": "string"
    },
    "project_drawer": {
      "type": "string",
      "description": "Dedicated drawer/gaveta for this project."
    },
    "project_domain": {
      "type": "string",
      "enum": [
        "media",
        "education",
        "science",
        "business",
        "home",
        "assistive",
        "general"
      ]
    },
    "workflow_type": {
      "type": "string",
      "enum": [
        "media_production",
        "teaching_flow",
        "research_flow",
        "business_flow",
        "home_flow",
        "assistive_flow",
        "general_flow"
      ]
    },
    "nome": {
      "type": "string"
    },
    "objetivo": {
      "type": "string"
    },
    "estado_global": {
      "type": "string",
      "enum": ["draft", "ativo", "revisao", "concluido", "arquivado"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "timeline_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "placement_mode": {
          "type": "string",
          "enum": ["automatico", "manual_revisado"]
        },
        "export_intent": {
          "type": "string",
          "enum": ["json_interno", "json_completo", "xml_futuro", "edl_futuro", "fcpxml_futuro"]
        },
        "revision_policy": {
          "type": "string",
          "enum": ["tracked", "strict_tracked"]
        }
      },
      "required": ["placement_mode", "export_intent", "revision_policy"]
    },
    "sequences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "sequence_id": {
            "type": "string"
          },
          "sequence_label": {
            "type": "string"
          },
          "sequence_index": {
            "type": "integer",
            "minimum": 0
          },
          "phase": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": ["sequence_id", "sequence_label", "sequence_index"]
      }
    },
    "blocks": {
      "type": "array",
      "description": "Universal work units and their anchored artifacts.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "block_id": {
            "type": "string"
          },
          "prompt_origin_id": {
            "type": "string",
            "description": "ID from Arm 09 prompt block."
          },
          "user_id": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "workflow_lane": {
            "type": "string",
            "enum": [
              "instruction",
              "evidence",
              "visual",
              "audio",
              "review",
              "support",
              "planning",
              "execution"
            ]
          },
          "track": {
            "type": "string",
            "description": "Optional media-specific track."
          },
          "sequence_id": {
            "type": "string"
          },
          "sequence_label": {
            "type": "string"
          },
          "sequence_index": {
            "type": "integer",
            "minimum": 0
          },
          "unit_id": {
            "type": "string"
          },
          "unit_type": {
            "type": "string",
            "enum": [
              "instruction_block",
              "planning_block",
              "teaching_block",
              "evidence_block",
              "media_block",
              "support_block",
              "review_block",
              "assistive_block"
            ]
          },
          "unit_goal": {
            "type": "string"
          },
          "phase": {
            "type": "string",
            "enum": [
              "capture",
              "plan",
              "generate",
              "validate",
              "organize",
              "review",
              "finalize"
            ]
          },
          "artifact_id": {
            "type": "string"
          },
          "artifact_type": {
            "type": "string",
            "enum": [
              "text",
              "speech",
              "image",
              "video",
              "audio",
              "graphic",
              "checklist",
              "table",
              "note",
              "task"
            ]
          },
          "target_tool": {
            "type": "string"
          },
          "expected_output": {
            "type": "string"
          },
          "expected_asset_match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string"
              },
              "filename_prefix": {
                "type": "string"
              },
              "artifact_type": {
                "type": "string"
              }
            },
            "required": ["artifact_type"]
          },
          "in_point_ms": {
            "type": "integer",
            "minimum": 0
          },
          "out_point_ms": {
            "type": "integer",
            "minimum": 0
          },
          "file_reference": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "prompt_pronto",
              "executando",
              "gerado",
              "revisao",
              "aprovado",
              "concluido",
              "descartado"
            ]
          },
          "dependency_targets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Legacy alias retained during migration."
          },
          "dependency_reason": {
            "type": "string"
          },
          "revision_of": {
            "type": ["string", "null"]
          },
          "revision_reason": {
            "type": "string"
          },
          "insertion_mode": {
            "type": "string",
            "enum": [
              "append",
              "insert_before",
              "insert_after",
              "replace",
              "fork_revision"
            ]
          },
          "supersedes": {
            "type": ["string", "null"]
          },
          "source_ai": {
            "type": "string",
            "description": "External AI that generated the final artifact."
          },
          "notes": {
            "type": "string"
          },
          "semantic_role": {
            "type": "string"
          }
        },
        "required": [
          "block_id",
          "prompt_origin_id",
          "workflow_lane",
          "sequence_id",
          "sequence_label",
          "sequence_index",
          "unit_id",
          "unit_type",
          "unit_goal",
          "phase",
          "artifact_type",
          "target_tool",
          "expected_asset_match",
          "status",
          "dependency_targets",
          "insertion_mode"
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "project_id",
    "project_drawer",
    "project_domain",
    "workflow_type",
    "nome",
    "objetivo",
    "estado_global",
    "created_at",
    "updated_at",
    "timeline_policy",
    "sequences",
    "blocks"
  ]
}
