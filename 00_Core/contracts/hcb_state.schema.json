{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HCBState",
  "description": "Dynamic operational state for a recognized HCB user.",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": ["study", "work", "creation", "research", "review", "support"]
    },
    "energy": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "focus": {
      "type": "string",
      "enum": ["scattered", "normal", "deep"]
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "cognitive_load": {
      "type": "string",
      "enum": ["light", "moderate", "heavy"]
    },
    "response_preference": {
      "type": "string",
      "enum": ["summary", "balanced", "detailed"]
    },
    "accessibility_flags": {
      "type": "object",
      "properties": {
        "fatigue_now": { "type": "boolean" },
        "pain_now": { "type": "boolean" },
        "visual_overload": { "type": "boolean" },
        "needs_pause": { "type": "boolean" }
      },
      "required": ["fatigue_now", "pain_now", "visual_overload", "needs_pause"]
    },
    "active_project": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "user_id",
    "session_id",
    "updated_at",
    "mode",
    "energy",
    "focus",
    "urgency",
    "cognitive_load",
    "response_preference",
    "accessibility_flags"
  ]
}
