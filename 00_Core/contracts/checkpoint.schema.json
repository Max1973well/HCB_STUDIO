{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Checkpoint",
  "description": "Schema for rest-safe continuity checkpoints",
  "type": "object",
  "properties": {
    "checkpoint_id": {
      "type": "string",
      "description": "Unique identifier for this checkpoint"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "state": {
      "type": "object",
      "description": "Snapshot of the current system or module state"
    },
    "retention_class": {
      "type": "string",
      "enum": ["immortal", "ephemeral"],
      "description": "Tag defining the deletion policy of this checkpoint"
    },
    "context": {
      "type": "object",
      "description": "Any active context, tool references, or open files to be restored"
    },
    "next_actions": {
      "type": "array",
      "description": "List of queued or planned actions to resume",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["checkpoint_id", "timestamp", "state", "retention_class"]
}
